<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════
         SEARCH VIEW — Aggiunge Applicativo e Sistema di pagamento
         come campi ricercabili e raggruppabili nella vista Contatti
    ═══════════════════════════════════════════════════════════════ -->
    <record id="res_partner_search_buildingpay" model="ir.ui.view">
        <field name="name">res.partner.search.buildingpay</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">

            <!-- Campi ricercabili (barra di ricerca) -->
            <xpath expr="//field[@name='name']" position="after">
                <field name="applicativo"
                       string="Applicativo"
                       filter_domain="[('applicativo', 'ilike', self)]"/>
                <field name="sistema_pagamento"
                       string="Sistema di pagamento"
                       filter_domain="[('sistema_pagamento', 'ilike', self)]"/>
            </xpath>

            <!-- Filtri per flag BuildingPay -->
            <xpath expr="//group" position="before">
                <filter string="È referrer"
                        name="filter_is_referrer"
                        domain="[('is_referrer', '=', True)]"/>
                <separator/>
            </xpath>

            <!-- Group By -->
            <xpath expr="//group" position="inside">
                <filter string="Applicativo"
                        name="group_by_applicativo"
                        context="{'group_by': 'applicativo'}"/>
                <filter string="Sistema di pagamento"
                        name="group_by_sistema_pagamento"
                        context="{'group_by': 'sistema_pagamento'}"/>
            </xpath>

        </field>
    </record>

    <!--
        BuildingPay v41 - Estensione res.partner
        Sintassi Odoo 17 EE:
        - invisible/readonly come espressioni Python dirette (no attrs)
        - Nessun list come type: usare tree
        - REGOLA modifier: campo in invisible= NON puo avere groups= su nessuna istanza
        - Tutti gli xpath usano //notebook (presente in base.view_partner_form)
          per evitare dipendenze da xmlid di altri moduli (es. account.*).
        - Tab BuildingPay e Referrer: nascosti per type=condominio
        - Tab Condominio: visibile SOLO per type=condominio; contiene dati
          fiscali, stato contratti, IBAN e istituto bancario
    -->

    <record id="view_partner_form_buildingpay" model="ir.ui.view">
        <field name="name">res.partner.form.buildingpay</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Codice ISTAT prima del campo Funzione (riga propria nel gruppo anagrafica) -->
            <xpath expr="//field[@name='function']" position="before">
                <field name="codice_istat" string="Codice ISTAT"/>
            </xpath>

            <!-- Icona edificio nella button_box per tipo condominio -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <div class="oe_stat_button"
                     invisible="type != 'condominio'"
                     groups="BuildingPay_onboarding_v15.group_buildingpay_user">
                    <i class="o_button_icon fa fa-fw fa-building"/>
                    <div class="o_stat_info">
                        <span class="o_stat_text">Condominio</span>
                    </div>
                </div>
            </xpath>

            <xpath expr="//notebook" position="inside">

                <!-- ═══════════════════════════════════════════════════════
                     TAB: BuildingPay — nascosto per i condomini
                     Contiene: flag amministratore, stato contratti
                ═══════════════════════════════════════════════════════ -->
                <page string="BuildingPay" name="buildingpay_page"
                      invisible="type == 'condominio'"
                      groups="BuildingPay_onboarding_v15.group_buildingpay_user">

                    <!-- is_amministratore senza groups= perche usato
                         in invisible= sul sub-tab Amministratore -->
                    <group string="Ruolo BuildingPay">
                        <!-- Flag "Amministratore validato" posizionato per primo:
                             l'operatore lo imposta a TRUE dopo aver controllato
                             i dati inseriti al momento della registrazione.
                             Fino a TRUE l'amministratore non può creare condomini. -->
                        <field name="is_amministratore_validato"
                               string="Amministratore validato"
                               widget="boolean_toggle"/>
                        <field name="is_amministratore"
                               string="Amministratore BuildingPay"
                               widget="boolean_toggle"/>
                        <field name="privacy_accepted"
                               string="Privacy accettata"
                               readonly="1"/>
                        <field name="privacy_accepted_date"
                               string="Data accettazione privacy"
                               readonly="1"
                               invisible="not privacy_accepted"/>
                    </group>

                    <notebook>
                        <page string="Amministratore"
                              name="bp_page_admin"
                              invisible="not is_amministratore">

                            <group string="Dati operativi">
                                <field name="applicativo" string="Applicativo"/>
                                <field name="sistema_pagamento" string="Sistemi di pagamento usati"/>
                            </group>

                            <separator string="Stato contratti"/>
                            <group>
                                <group string="Accordo Amministratore">
                                    <!-- Documento caricato dall'amministratore dal portale -->
                                    <field name="accordo_retrocessioni_ed"
                                           string="Accordo amministratore"
                                           readonly="1"/>
                                    <field name="accordo_retrocessioni_file"
                                           string="Scarica accordo amministratore"
                                           widget="binary"
                                           readonly="1"
                                           filename="accordo_retrocessioni_filename"
                                           invisible="not accordo_retrocessioni_ed"/>
                                    <field name="accordo_retrocessioni_filename"
                                           readonly="1"
                                           invisible="not accordo_retrocessioni_ed"/>
                                    <field name="accordo_retrocessioni_upload_date"
                                           readonly="1"
                                           invisible="not accordo_retrocessioni_ed"/>
                                    <!-- Visibile e modificabile solo quando l'admin ha
                                         caricato il contratto (accordo_retrocessioni_ed = True) -->
                                    <field name="contratto_amministratore_pes"
                                           string="Contratto Amministratore firmato da Pes"
                                           widget="binary"
                                           filename="contratto_amministratore_pes_filename"
                                           invisible="not accordo_retrocessioni_ed"/>
                                    <field name="contratto_amministratore_pes_filename"
                                           invisible="not accordo_retrocessioni_ed or not contratto_amministratore_pes"/>
                                    <field name="contratto_amministratore_pes_upload_date"
                                           string="Caricato il"
                                           readonly="1"
                                           invisible="not contratto_amministratore_pes"/>
                                    <field name="contratto_amministratore_pes_upload_user_id"
                                           string="Caricato da"
                                           readonly="1"
                                           invisible="not contratto_amministratore_pes"/>
                                </group>
                                <group string="Accordo Condomini Aggregati">
                                    <!-- Documento caricato dall'amministratore dal portale -->
                                    <field name="accordo_condomini_aggregati_ed"
                                           string="Accordo Condomini Aggregati"
                                           readonly="1"/>
                                    <field name="accordo_condomini_file"
                                           string="Scarica accordo condomini"
                                           widget="binary"
                                           readonly="1"
                                           filename="accordo_condomini_filename"
                                           invisible="not accordo_condomini_aggregati_ed"/>
                                    <field name="accordo_condomini_filename"
                                           readonly="1"
                                           invisible="not accordo_condomini_aggregati_ed"/>
                                    <field name="accordo_condomini_upload_date"
                                           readonly="1"
                                           invisible="not accordo_condomini_aggregati_ed"/>
                                    <!-- Modificabile solo quando l'admin ha caricato
                                         l'accordo (accordo_condomini_aggregati_ed = True) -->
                                    <field name="accordo_condomini_pes"
                                           string="Accordo Condomini Aggregati firmato da Pes"
                                           widget="binary"
                                           filename="accordo_condomini_pes_filename"
                                           readonly="not accordo_condomini_aggregati_ed"/>
                                    <field name="accordo_condomini_pes_filename"
                                           readonly="not accordo_condomini_aggregati_ed"
                                           invisible="not accordo_condomini_pes"/>
                                    <field name="accordo_condomini_pes_upload_date"
                                           string="Caricato il"
                                           readonly="1"
                                           invisible="not accordo_condomini_pes"/>
                                    <field name="accordo_condomini_pes_upload_user_id"
                                           string="Caricato da"
                                           readonly="1"
                                           invisible="not accordo_condomini_pes"/>
                                </group>
                            </group>
                        </page>
                    </notebook>

                </page>

                <!-- ═══════════════════════════════════════════════════════
                     TAB: Referrer — nascosto per i condomini
                ═══════════════════════════════════════════════════════ -->
                <page string="Referrer" name="bp_referrer_page"
                      invisible="type == 'condominio'"
                      groups="BuildingPay_onboarding_v15.group_buildingpay_referrer_responsabile">

                    <group>
                        <field name="referrer_id"
                               string="Invitato da (Referrer)"
                               domain="[('referrer_code', 'not in', [False, ''])]"/>

                        <label for="referrer_code" string="Codice Referrer (8 car.)"/>
                        <div class="o_row">
                            <field name="referrer_code"
                                   nolabel="1"
                                   placeholder="Es. AB12CD34"
                                   groups="BuildingPay_onboarding_v15.group_buildingpay_manager"/>
                            <field name="referrer_code"
                                   nolabel="1"
                                   readonly="1"
                                   groups="!BuildingPay_onboarding_v15.group_buildingpay_manager"/>
                            <button name="action_generate_referrer_code"
                                    type="object"
                                    string="&#x27F3; Genera"
                                    class="btn btn-secondary btn-sm ms-1"
                                    groups="BuildingPay_onboarding_v15.group_buildingpay_manager"/>
                        </div>

                        <label for="referral_url" string="Link di invito"/>
                        <div>
                            <field name="referral_url"
                                   nolabel="1"
                                   readonly="1"
                                   widget="CopyClipboardChar"
                                   invisible="not referral_url"/>
                            <span class="text-muted small"
                                  invisible="referral_url">
                                Imposta un codice referrer per generare il link.
                            </span>
                        </div>

                        <label for="referred_ids" string="Amministratori invitati"/>
                        <field name="referred_ids"
                               nolabel="1"
                               readonly="1"
                               widget="many2many_tags"/>
                    </group>

                    <separator string="Dati Fornitura"/>

                    <group>
                        <field name="is_referrer"
                               string="È un referrer"
                               widget="boolean_toggle"/>
                    </group>

                    <group invisible="not is_referrer">
                        <group string="Condizioni economiche">
                            <label for="valore_retrocessione" string="Valore retrocessione promotore"/>
                            <div class="o_row">
                                <field name="valore_retrocessione" nolabel="1"/>
                                <field name="retrocessione_currency_id"
                                       nolabel="1"
                                       readonly="1"
                                       options="{'no_open': True}"/>
                            </div>
                            <label for="valore_retrocessione_amministratore"
                                   string="Valore retrocessione amministratore"/>
                            <div class="o_row">
                                <field name="valore_retrocessione_amministratore" nolabel="1"/>
                                <field name="company_currency_id"
                                       nolabel="1"
                                       readonly="1"
                                       options="{'no_open': True}"/>
                            </div>
                        </group>
                        <group string="Template contratto">
                            <field name="contratto_retrocessione_standard"
                                   string="Contratto condizioni di fornitura standard"
                                   widget="boolean_toggle"/>
                            <field name="contratto_retrocessione_custom_file"
                                   string="Contratto condizioni di fornitura (personalizzato)"
                                   widget="binary"
                                   filename="contratto_retrocessione_custom_filename"
                                   invisible="contratto_retrocessione_standard"/>
                            <field name="contratto_retrocessione_custom_filename"
                                   invisible="contratto_retrocessione_standard"/>
                        </group>
                    </group>

                </page>

                <!-- ═══════════════════════════════════════════════════════
                     TAB: Condominio — visibile SOLO per type=condominio
                     Contiene: dati fiscali, stato, IBAN e istituto bancario
                     Sostituisce la ex sub-tab "Dati Condominio" che era
                     dentro il tab BuildingPay (ormai nascosto per condomini).
                     Non usa xpath su accounting_tab per evitare dipendenze
                     da xmlid di moduli esterni con nomi variabili tra
                     versioni CE/EE di Odoo.
                ═══════════════════════════════════════════════════════ -->
                <page string="Condominio" name="bp_condominio_main_page"
                      invisible="type != 'condominio'"
                      groups="BuildingPay_onboarding_v15.group_buildingpay_user">

                    <group>
                        <group string="Stato">
                            <field name="data_archiviazione" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Dati bancari"/>
                    <field name="bank_ids" nolabel="1">
                        <tree editable="bottom" string="Conti bancari">
                            <field name="acc_number" string="IBAN"/>
                            <field name="bank_id" string="Istituto bancario"/>
                        </tree>
                    </field>

                </page>

            </xpath>

        </field>
    </record>

</odoo>
