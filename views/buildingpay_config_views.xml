<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        BuildingPay - Configurazione
        Sintassi Odoo 17 EE:
        - attrs rimosso: si usano invisible/required/readonly come espressioni Python dirette
        - Esempi: invisible="not create_activity_on_contract"
                  required="create_activity_on_contract"
    -->

    <!-- ================================================
         FORM VIEW: buildingpay_v36.config
    ================================================= -->
    <record id="view_buildingpay_config_form" model="ir.ui.view">
        <field name="name">buildingpay_v36.config.form</field>
        <field name="model">buildingpay_v36.config</field>
        <field name="arch" type="xml">
            <form string="Configurazione BuildingPay">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="website_id" options="{'no_create': True}"/>
                        </h1>
                    </div>

                    <notebook>
                        <!-- Tab: Template Accordo Retrocessioni -->
                        <page string="Template Accordo Retrocessioni" name="template_retrocessioni">
                            <p class="text-muted">
                                File .docx con i seguenti placeholder:
                                [NOME AMMINISTRATORE], [CODICE FISCALE], [IBAN], [NOME BANCA], [DATA]
                            </p>
                            <group>
                                <field name="accordo_retrocessioni_template" widget="binary"
                                       filename="accordo_retrocessioni_template_filename"/>
                                <field name="accordo_retrocessioni_template_filename"/>
                            </group>
                        </page>

                        <!-- Tab: Template Accordo Condomini -->
                        <page string="Template Accordo Condomini" name="template_condomini">
                            <p class="text-muted">
                                File .docx con i seguenti placeholder:
                                [NOME AMMINISTRATORE], [________] (CF), [ALLEGATO_A] (tabella condomini)
                            </p>
                            <group>
                                <field name="contratto_template" widget="binary"
                                       filename="contratto_template_filename"/>
                                <field name="contratto_template_filename"/>
                            </group>
                        </page>

                        <!-- Tab: Attivita automatica -->
                        <page string="Attività Automatiche" name="activity">

                            <!-- ── Attività: caricamento Accordo Amministratore ── -->
                            <separator string="Caricamento Accordo Amministratore"/>
                            <p class="text-muted small">
                                Quando l'amministratore carica il file "Accordo Amministratore"
                                firmato dal portale, viene creata un'attività "To Do" per
                                ogni assegnatario configurato.
                            </p>
                            <group>
                                <field name="create_activity_on_accordo_admin"/>
                            </group>
                            <group invisible="not create_activity_on_accordo_admin">
                                <group string="Configurazione attività">
                                    <field name="activity_accordo_admin_days"
                                           required="create_activity_on_accordo_admin"/>
                                </group>
                                <group string="Assegnatari (fino a 4)">
                                    <field name="activity_accordo_admin_responsible_1_id"
                                           required="create_activity_on_accordo_admin"
                                           string="Assegnatario 1 *"/>
                                    <field name="activity_accordo_admin_responsible_2_id"
                                           string="Assegnatario 2"/>
                                    <field name="activity_accordo_admin_responsible_3_id"
                                           string="Assegnatario 3"/>
                                    <field name="activity_accordo_admin_responsible_4_id"
                                           string="Assegnatario 4"/>
                                </group>
                            </group>

                            <!-- ── Attività: nuovo amministratore registrato ── -->
                            <separator string="Registrazione nuovo amministratore"/>
                            <p class="text-muted small">
                                Quando un amministratore completa la registrazione dal sito web,
                                viene creata un'attività "To Do" per controllare i dati inseriti
                                e impostare il flag "Amministratore validato".
                                Finché il flag è FALSE, l'amministratore non può creare condomini.
                            </p>
                            <group>
                                <field name="create_activity_on_new_admin"/>
                            </group>
                            <group invisible="not create_activity_on_new_admin">
                                <group string="Configurazione attività (nuovo admin)">
                                    <field name="activity_new_admin_days"
                                           required="create_activity_on_new_admin"/>
                                </group>
                                <group string="Assegnatari (fino a 4)">
                                    <field name="activity_new_admin_responsible_1_id"
                                           required="create_activity_on_new_admin"
                                           string="Assegnatario 1 *"/>
                                    <field name="activity_new_admin_responsible_2_id"
                                           string="Assegnatario 2"/>
                                    <field name="activity_new_admin_responsible_3_id"
                                           string="Assegnatario 3"/>
                                    <field name="activity_new_admin_responsible_4_id"
                                           string="Assegnatario 4"/>
                                </group>
                            </group>

                            <!-- ── Attività: caricamento Accordo Condomini Aggregati ── -->
                            <separator string="Caricamento Accordo Condomini Aggregati"/>
                            <group>
                                <field name="create_activity_on_contract"/>
                            </group>
                            <group invisible="not create_activity_on_contract">
                                <group string="Configurazione attività (accordo condomini)">
                                    <field name="activity_days"
                                           required="create_activity_on_contract"/>
                                </group>
                                <group string="Assegnatari (fino a 4)">
                                    <field name="activity_responsible_id"
                                           required="create_activity_on_contract"
                                           string="Assegnatario 1 *"/>
                                    <field name="activity_responsible_2_id"
                                           string="Assegnatario 2"/>
                                    <field name="activity_responsible_3_id"
                                           string="Assegnatario 3"/>
                                    <field name="activity_responsible_4_id"
                                           string="Assegnatario 4"/>
                                </group>
                            </group>

                        </page>

                        <!-- Tab: CRM / Richieste informazioni -->
                        <page string="CRM / Richieste informazioni" name="crm_settings">
                            <p class="text-muted">
                                Configurazione per la gestione dei lead CRM generati
                                dalle richieste di informazioni ricevute dal form di registrazione.
                            </p>

                            <separator string="Addetto vendite"/>
                            <group>
                                <group>
                                    <field name="default_salesperson_id"
                                           options="{'no_create': True}"/>
                                </group>
                            </group>

                            <separator string="Attività automatica alla ricezione di una richiesta informazioni"/>
                            <p class="text-muted small">
                                Quando un visitatore invia una richiesta di informazioni dal form di registrazione,
                                viene creata un'attività "To Do" per ogni assegnatario configurato.
                                Scadenza: oggi + giorni configurati.
                            </p>
                            <group>
                                <group string="Scadenza">
                                    <field name="activity_info_lead_days"/>
                                </group>
                                <group string="Assegnatari (fino a 3)">
                                    <field name="activity_info_lead_responsible_1_id"
                                           string="Assegnatario 1"
                                           options="{'no_create': True}"/>
                                    <field name="activity_info_lead_responsible_2_id"
                                           string="Assegnatario 2"
                                           options="{'no_create': True}"/>
                                    <field name="activity_info_lead_responsible_3_id"
                                           string="Assegnatario 3"
                                           options="{'no_create': True}"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab: Destinatari email -->
                        <page string="Destinatari Email" name="emails">
                            <group>
                                <group string="Report condomini attivi">
                                    <field name="condomini_attivati_email"
                                           placeholder="email1@esempio.it, email2@esempio.it"/>
                                </group>
                                <group string="Notifica condomini dismessi">
                                    <field name="condomini_dismessi_email"
                                           placeholder="email1@esempio.it, email2@esempio.it"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================
         LIST VIEW: buildingpay_v36.config
    ================================================= -->
    <record id="view_buildingpay_config_list" model="ir.ui.view">
        <field name="name">buildingpay_v36.config.list</field>
        <field name="model">buildingpay_v36.config</field>
        <field name="arch" type="xml">
            <tree string="Configurazioni BuildingPay">
                <field name="website_id"/>
                <field name="create_activity_on_contract"/>
                <field name="activity_responsible_id"/>
                <field name="activity_days"/>
                <field name="condomini_attivati_email"/>
            </tree>
        </field>
    </record>

    <!-- ================================================
         ACTION: buildingpay_v36.config
    ================================================= -->
    <record id="action_buildingpay_config" model="ir.actions.act_window">
        <field name="name">Configurazione BuildingPay</field>
        <field name="res_model">buildingpay_v36.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea la prima configurazione BuildingPay
            </p>
            <p>
                Configura il sito web, il template del contratto e le
                impostazioni per le attività automatiche.
            </p>
        </field>
    </record>
</odoo>
